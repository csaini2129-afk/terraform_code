# Azure Provider source and version being used
terraform {
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "=4.7.0"
    }
  }
}

# Configure the Microsoft Azure Provider
provider "azurerm" {
  features {}

  resource "azurerm_resource_group" "rgs3" {
  name     = saini3
  location = "westtus"
}
  resource "azurerm_resource_group" "rgs4" {
  name     = saini4
  location = "northindia"
}
